# Koyeb injects PORT automatically for web services.
NODE_ENV=production
CLIENT_URL=https://your-frontend.vercel.app
SERVER_URL=https://{{ KOYEB_PUBLIC_DOMAIN }}
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/staps
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=staps_token
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=re_xxx
MAIL_FROM=STAPS <noreply@yourdomain.com>
SMTP_DEBUG=false
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=15000
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CALLBACK_URL=https://your-frontend.vercel.app/payment/callback
PASSWORD_RESET_CODE_TTL_MINUTES=15
VENDOR_REGISTRATION_FEE=1000
AUTO_CONFIRM_HOURS=72
CANCEL_WINDOW_MINUTES=90
